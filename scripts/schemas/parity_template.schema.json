{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://find-ideal-estate.local/schemas/parity_template.schema.json",
  "title": "Legacy Parity Template",
  "type": "object",
  "required": [
    "template_version",
    "generated_at",
    "source",
    "query",
    "strict_count_parity",
    "required_fields",
    "platform_field_presence",
    "canonical_results"
  ],
  "additionalProperties": false,
  "properties": {
    "template_version": {
      "type": "string",
      "pattern": "^v[0-9]+(\\.[0-9]+)?$"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": ["type", "script", "config"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "legacy_cods_ok"
        },
        "script": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "query": {
      "type": "object",
      "required": ["address", "mode", "center", "radius_m", "max_pages"],
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["rent", "buy", "sale"]
        },
        "center": {
          "type": "object",
          "required": ["lat", "lon"],
          "additionalProperties": false,
          "properties": {
            "lat": {
              "type": "number"
            },
            "lon": {
              "type": "number"
            }
          }
        },
        "radius_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_pages": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "strict_count_parity": {
      "type": "object",
      "required": ["quintoandar", "vivareal", "zapimoveis"],
      "additionalProperties": false,
      "properties": {
        "quintoandar": {
          "type": "integer",
          "minimum": 0
        },
        "vivareal": {
          "type": "integer",
          "minimum": 0
        },
        "zapimoveis": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "required_fields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "platform_field_presence": {
      "type": "object",
      "required": ["quintoandar", "vivareal", "zapimoveis"],
      "additionalProperties": false,
      "properties": {
        "quintoandar": {
          "$ref": "#/$defs/platformStats"
        },
        "vivareal": {
          "$ref": "#/$defs/platformStats"
        },
        "zapimoveis": {
          "$ref": "#/$defs/platformStats"
        }
      }
    },
    "canonical_results": {
      "type": "object",
      "required": ["quintoandar", "vivareal", "zapimoveis"],
      "additionalProperties": false,
      "properties": {
        "quintoandar": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/listingSnapshot"
          }
        },
        "vivareal": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/listingSnapshot"
          }
        },
        "zapimoveis": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/listingSnapshot"
          }
        }
      }
    }
  },
  "$defs": {
    "listingSnapshot": {
      "type": "object",
      "required": ["platform", "listing_id", "url"],
      "additionalProperties": false,
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["quintoandar", "vivareal", "zapimoveis"]
        },
        "listing_id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "lat": {
          "type": ["number", "null"]
        },
        "lon": {
          "type": ["number", "null"]
        },
        "price_brl": {
          "type": ["number", "null"]
        },
        "area_m2": {
          "type": ["number", "null"]
        },
        "bedrooms": {
          "type": ["integer", "null"]
        },
        "bathrooms": {
          "type": ["integer", "null"]
        },
        "parking": {
          "type": ["integer", "null"]
        },
        "address": {
          "type": ["string", "null"]
        }
      }
    },
    "platformStats": {
      "type": "object",
      "required": ["count", "presence"],
      "additionalProperties": false,
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "presence": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/fieldPresence"
          }
        }
      }
    },
    "fieldPresence": {
      "type": "object",
      "required": ["present", "missing", "rate"],
      "additionalProperties": false,
      "properties": {
        "present": {
          "type": "integer",
          "minimum": 0
        },
        "missing": {
          "type": "integer",
          "minimum": 0
        },
        "rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
